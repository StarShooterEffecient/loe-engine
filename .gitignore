# LOE Engine — files that should NOT go on GitHub
# (these are generated locally or are large intermediate data; the pipeline recreates them)

# Python cruft
__pycache__/
*.pyc
*.pyo
.Python
venv/
.venv/

# The canonical page store — large, rebuilt from the mirror by ingest.py / mirror_sync.py
wiki.db
wiki_prev.db
*.db

# Logs and run output
*.log
run.log
sync.log

# Archived / snapshot versions kept during development (not needed on GitHub)
*_prev.json
*_pre_*.json
*_illegal*.json
*_regex_old.py
*.snapshot

# The mirror's downloaded pages — regenerated by mirror_fetch.py; only manifest.json is tracked
mirror/*.wikitext
mirror/full_content.json

# OS noise
.DS_Store
Thumbs.db
